{
  "name": "vendrop",
  "version": "1.0.0",
  "description": "Minify and copy vendor JS dependencies to your public folder. Vite plugin, Astro compatible, and CLI included.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "vendrop": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsup src/index.ts src/cli.ts --format esm --dts"
  },
  "keywords": [
    "vite",
    "astro",
    "nextjs",
    "vendor",
    "minify",
    "terser",
    "copy",
    "bundle",
    "cli",
    "node_modules",
    "public"
  ],
  "author": "J.P. Esparza",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "terser": "^5.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TU_USUARIO/vendrop.git"
  },
  "bugs": {
    "url": "https://github.com/TU_USUARIO/vendrop/issues"
  },
  "homepage": "https://github.com/TU_USUARIO/vendrop#readme"
}